# =============================================================================
# SETUP (one time): copy this file to application-local-secret.properties
#   Same folder: src/main/resources/
#
#   PowerShell:
#     copy src\main\resources\application-local-secret.properties.example src\main\resources\application-local-secret.properties
#
# Then edit the URI below. URL-encode special characters in the password (@ → %40).
# application-local-secret.properties is gitignored — never commit real passwords.
# =============================================================================

spring.data.mongodb.uri=mongodb+srv://YOUR_DB_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/smart_inventory?retryWrites=true&w=majority&appName=Cluster0
