# Copy to .env or set these in your environment / IDE / terminal before running the app.

# MongoDB (default: mongodb://localhost:27017/smart_inventory)
# For MongoDB Atlas: URL-encode special chars in password (@ -> %40)
MONGODB_URI=mongodb://localhost:27017/smart_inventory
